{
  "schemaVersion": 1,
  "id": "zai",
  "name": "Z.ai",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#2D2D2D",
  "auth": {
    "defaultStrategyId": "apiKey",
    "strategies": [
      {
        "id": "apiKey",
        "label": "API Key",
        "kind": "apiKey",
        "fields": [
          { "name": "apiKey", "label": "API Key", "fieldType": "password", "secret": true, "required": true },
          {
            "name": "apiRegion",
            "label": "Region",
            "fieldType": "segmented",
            "defaultValue": "global",
            "options": [
              { "label": "Global", "value": "global" },
              { "label": "China", "value": "cn" }
            ]
          },
          {
            "name": "apiHost",
            "label": "API Host",
            "fieldType": "text",
            "placeholder": "https://api.z.ai",
            "advanced": true
          },
          {
            "name": "quotaUrl",
            "label": "Quota URL",
            "fieldType": "text",
            "placeholder": "https://api.z.ai/api/monitor/usage/quota/limit",
            "advanced": true
          }
        ],
        "credentialTemplate": { "apiKey": "", "apiHost": "", "quotaUrl": "", "apiRegion": "" },
        "importSources": [
          {
            "id": "env-api-key",
            "kind": "env",
            "envs": ["ZAI_API_KEY", "GLM_API_KEY"],
            "text": {
              "target": "apiKey",
              "constants": { "type": "apiKey" }
            }
          }
        ]
      }
    ]
  },
  "lines": [
    { "type": "progress", "label": "Session", "scope": "overview", "primaryOrder": 1 },
    { "type": "progress", "label": "Weekly", "scope": "overview" },
    { "type": "progress", "label": "Web Searches", "scope": "overview" }
  ]
}
